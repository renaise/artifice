---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { site as s } from "../content/settings";

const tabs = [
  { label: "Mission", body: "Artifice NYC is a curatorial research nonprofit working between creative science and new media fictions. We produce immersive, site-specific showcases and open creative infrastructure, a public archive practitioners build and control, shaping how speculative practice and emerging technology define the way we live." },
  { label: "Vision", body: "A future where experimental work reaches the public while it is still being made, and the record of how it was made stays open for anyone to read." },
  { label: "What We Do", body: "We show the artifacts of science fiction across Chapters and nodes, and keep a public record of their making in the Artifact Index." },
];

const board = [
  { name: "Renaise Kim", role: "Executive Director", photo: "/img/about/team/renaise.png" },
  { name: "Kassandra Schengili", role: "Vice Chair", photo: "/img/about/team/kassandra.png" },
  { name: "Sarah Kim", role: "Treasurer", photo: "/img/about/team/sarah.jpg" },
  { name: "Ethan Proia", role: "Secretary", photo: "/img/about/team/ethan.jpg" },
];
const core = [
  { name: "Renaise Kim", role: "Creative Director", photo: "/img/about/team/renaise.png" },
  { name: "Kassandra Schengili", role: "Development Director", photo: "/img/about/team/kassandra.png" },
  { name: "Woo Kim", role: "Programs Director", photo: "/img/about/team/woo.png" },
  { name: "Sarah Kim", role: "Communications Manager", photo: "/img/about/team/sarah.jpg" },
];

const socials = ["EMAIL", "LINKTREE", "INSTAGRAM", "YOUTUBE", "SUBSTACK", "LINKEDIN"];
---

<Base title="ARTIFICE">
  <a id="top"></a>
  <Nav />

  <main>
    {/* MISSION / VISION / WHAT WE DO — scroll-pinned sequence (opens the page; no duplicate hero) */}
    <section class="mvw" id="mvw">
      <div class="mvw-sticky">
        <div class="mvw-tabs">
          {tabs.map((t, i) => (
            <div class={"mvw-tab" + (i === 0 ? " on" : "")} data-i={i}>
              <img class="mvw-mark" src="/img/about/mission-mark.svg" alt="" />{t.label}
            </div>
          ))}
        </div>
        <div class="mvw-body">
          {tabs.map((t, i) => (
            <p class={"mvw-text" + (i === 0 ? " on" : "")} data-i={i}>{t.body}</p>
          ))}
        </div>
      </div>
      <div class="mvw-stack">
        {tabs.map((t) => (
          <div class="mvw-item">
            <div class="mvw-ilabel"><img class="mvw-mark" src="/img/about/mission-mark.svg" alt="" />{t.label}</div>
            <p class="mvw-ibody">{t.body}</p>
          </div>
        ))}
      </div>
    </section>

    {/* WHITEBOX */}
    <section class="abox">
      <div class="abox-mark">
        <div class="amark-icon-wrap">
          <img class="amark-icon" src="/img/whitebox-mark.png" alt="WHITEBOX" />
          <span class="amark-eyebrow">SCIENCE</span>
        </div>
        <img class="amark-word" src="/img/wb-word.png" alt="WHITEBOX" />
        <span class="amark-sub">SHOWROOM + CONCEPT LAB</span>
      </div>
      <div class="abox-grid"><img src="/img/about/wb-grid.png" alt="WHITEBOX showcases" loading="lazy" /></div>
    </section>

    {/* BLACKBOX */}
    <section class="abox">
      <div class="abox-mark">
        <div class="amark-icon-wrap">
          <img class="amark-icon" src="/img/blackbox-mark.png" alt="BLACKBOX" />
          <span class="amark-eyebrow dark">FICTION</span>
        </div>
        <img class="amark-word" src="/img/bb-word.png" alt="BLACKBOX" />
        <span class="amark-sub">NEW MEDIA FICTIONS + STAGE</span>
      </div>
      <div class="abox-grid"><img src="/img/about/bb-grid.png" alt="BLACKBOX showcases" loading="lazy" /></div>
    </section>

    {/* TEAM */}
    <section class="team-sec">
      <div class="team-col">
        <h2>Board of Directors</h2>
        <div class="team-row">
          {board.map((m) => (
            <div class="member">
              <div class="m-photo"><img src={m.photo} alt={m.name} loading="lazy" onerror="this.style.opacity=0" /></div>
              <span class="m-name">{m.name}</span>
              <span class="m-role">{m.role}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="team-col">
        <h2>Core Team</h2>
        <div class="team-row">
          {core.map((m) => (
            <div class="member">
              <div class="m-photo"><img src={m.photo} alt={m.name} loading="lazy" onerror="this.style.opacity=0" /></div>
              <span class="m-name">{m.name}</span>
              <span class="m-role">{m.role}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* GET INVOLVED */}
    <section class="involved">
      <div class="inv-left">
        <h2>Get involved</h2>
        <p>Membership keeps the artifacts of science fiction in public and the record open.</p>
      </div>
      <form class="inv-form" action="https://artificenyc.substack.com/subscribe" method="get" target="_blank" rel="noopener">
        <input class="inv-input" type="email" name="email" placeholder="ENTER EMAIL" aria-label="Email" autocomplete="off" />
        <button class="pill" type="submit">JOIN THE LIST</button>
      </form>
    </section>

  </main>

  <Footer />

  <style>
    main { position: relative; z-index: 1; background: linear-gradient(180deg, #0e0e0e 0%, #0e0e0e 87%, #2c2c2c 100%); }
    :global(body) { background: #0e0e0e; }

    /* shared pill button */
    .pill { font-family: var(--font-mono); font-size: 13px; letter-spacing: -0.02em; text-transform: uppercase; color: #fff; background: rgba(255,255,255,0.12); border: 0; border-radius: 6px; padding: 12px 20px; cursor: pointer; transition: background 0.2s ease, color 0.2s ease; display: inline-flex; align-items: center; justify-content: center; }
    .pill:hover { background: #fff; color: #0e0e0e; }
    .pill.big { border-radius: 10px; font-size: 13px; }

    /* HERO */
    .hero { position: relative; width: 100%; height: clamp(520px, 50vw, 960px); overflow: hidden; background: #000; }
    .hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
    .hero-center { position: absolute; left: 50%; top: 52%; transform: translate(-50%,-50%); z-index: 2; width: min(92vw, 560px); display: flex; flex-direction: column; align-items: center; text-align: center; gap: 18px; }
    .hero-lockup { width: clamp(200px, 24vw, 300px); height: auto; filter: brightness(0) invert(1); }
    .hero-mission { margin: 0; max-width: 48ch; font-family: var(--font-display); font-size: clamp(13px,1.1vw,18px); line-height: 1.5; color: #fff; }
    .hero-mission + .hero-mission { margin-top: -6px; }

    /* MVW */
    .mvw { position: relative; height: 300vh; }
    .mvw-sticky { position: sticky; top: 0; height: 100vh; display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 8%; align-items: center; padding: 0 clamp(40px, 4vw, 77px); max-width: 1920px; margin: 0 auto; }
    .mvw-tabs { display: flex; flex-direction: column; gap: 14px; }
    .mvw-tab { display: flex; align-items: center; gap: 22px; font-family: var(--font-display); font-size: clamp(34px,4vw,64px); letter-spacing: -0.01em; line-height: 1.1; color: #fff; opacity: 0.2; transition: opacity 0.35s ease; }
    .mvw-tab.on { opacity: 1; }
    .mvw-mark { width: clamp(30px,3vw,46px); height: auto; opacity: 0; transition: opacity 0.35s ease; }
    .mvw-tab.on .mvw-mark { opacity: 1; }
    .mvw-body { position: relative; min-height: 8em; }
    .mvw-text { position: absolute; inset: 0; opacity: 0; transform: translateY(10px); transition: opacity 0.4s ease, transform 0.4s ease; font-family: var(--font-display); font-size: clamp(22px,2.6vw,48px); line-height: 1.1; letter-spacing: -0.01em; color: #fff; margin: 0; pointer-events: none; }
    .mvw-text.on { opacity: 1; transform: none; }
    .mvw-stack { display: none; }
    .mvw-ilabel { display: flex; align-items: center; gap: 16px; font-family: var(--font-display); font-size: clamp(30px,8vw,40px); line-height: 1.1; color: #fff; margin-bottom: 14px; }
    .mvw-ilabel .mvw-mark { width: 34px; opacity: 1; }
    .mvw-ibody { font-family: var(--font-display); font-size: clamp(18px,4.6vw,22px); line-height: 1.3; letter-spacing: -0.01em; color: #fff; margin: 0; }

    /* WB/BB about boxes */
    .abox { display: grid; grid-template-columns: 1fr 1fr; gap: 5%; align-items: center; padding: clamp(60px,7vw,110px) clamp(40px,4vw,64px); max-width: 1920px; margin: 0 auto; border-top: 1px solid rgba(255,255,255,0.12); }
    .abox-mark { display: flex; flex-direction: column; align-items: flex-start; position: relative; }
    .amark-icon-wrap { position: relative; display: inline-block; }
    .amark-eyebrow { position: absolute; left: 50%; top: 51%; transform: translate(-50%, -50%); font-family: var(--font-mono); font-size: clamp(11px, 1.1vw, 16px); letter-spacing: 0; text-transform: uppercase; color: #fff; white-space: nowrap; pointer-events: none; }
    .amark-eyebrow.dark { color: #0e0e0e; }
    .amark-icon { width: clamp(180px, 18vw, 320px); height: auto; display: block; filter: brightness(0) invert(1); }
    .amark-word { width: clamp(200px, 17vw, 327px); height: auto; display: block; margin-top: 18px; }
    .amark-sub { font-family: var(--font-display); font-size: clamp(15px, 1.4vw, 24px); letter-spacing: 0; text-transform: uppercase; color: #fff; margin-top: 10px; }
    .abox-grid img { width: 100%; height: auto; display: block; }

    /* TEAM */
    .team-sec { display: grid; grid-template-columns: 1fr 1fr; gap: 6%; padding: clamp(50px,5vw,80px) clamp(40px,4vw,65px); max-width: 1920px; margin: 0 auto; border-top: 1px solid rgba(255,255,255,0.12); }
    .team-sec h2 { font-family: var(--font-display); font-size: clamp(28px,3vw,48px); font-weight: 400; letter-spacing: -0.01em; color: #fff; margin-bottom: 34px; }
    .team-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
    .member { display: flex; flex-direction: column; align-items: center; gap: 10px; }
    .m-photo { width: 100%; aspect-ratio: 185/190; background: #1a1a1a; overflow: hidden; }
    .m-photo img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1); }
    .m-name { font-family: var(--font-display); font-size: clamp(13px,1.3vw,24px); color: #fff; text-align: center; }
    .m-role { font-family: var(--font-display); font-size: clamp(9px,0.7vw,12px); letter-spacing: -0.01em; text-transform: uppercase; color: #fff; opacity: 0.7; text-align: center; }

    /* GET INVOLVED */
    .involved { display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; padding: clamp(50px,5vw,72px) clamp(40px,4vw,62px); max-width: 1920px; margin: 0 auto; border-top: 1px solid rgba(255,255,255,0.12); }
    .inv-left h2 { font-family: var(--font-display); font-size: clamp(28px,3vw,48px); font-weight: 400; color: #fff; }
    .inv-left p { font-family: var(--font-display); font-size: clamp(14px,1.4vw,24px); color: #fff; opacity: 0.85; margin-top: 14px; }
    .inv-form { display: flex; align-items: stretch; gap: 12px; }
    .inv-input { font-family: var(--font-mono); font-size: 14px; letter-spacing: -0.02em; text-transform: uppercase; color: #fff; background: rgba(255,255,255,0.02); border: 0; border-bottom: 1px solid #fff; padding: 11px 16px; min-width: clamp(220px, 26vw, 412px); }
    .inv-input::placeholder { color: rgba(255,255,255,0.4); }
    .inv-input:focus { outline: none; }

    /* FOOTER */
    .afx-footer { padding: clamp(60px,8vw,120px) clamp(33px,3vw,40px) 28px; max-width: 1920px; margin: 0 auto; }
    .afx-wordmark { width: 100%; max-width: 1848px; height: auto; display: block; margin: 0 auto clamp(28px,3vw,40px); }
    .afx-footrow { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
    .afx-left { display: flex; flex-direction: column; gap: 14px; }
    .afx-info { font-family: var(--font-mono); font-size: 14px; letter-spacing: -0.02em; text-transform: uppercase; color: #fff; opacity: 0.85; }
    .afx-socials { display: flex; gap: clamp(16px,2vw,40px); flex-wrap: wrap; }
    .afx-socials a { font-family: var(--font-display); font-size: clamp(14px,1.4vw,24px); letter-spacing: -0.01em; text-transform: uppercase; color: #fff; transition: opacity 0.2s ease; }
    .afx-socials a:hover { opacity: 0.55; }
    .afx-right { display: flex; align-items: center; gap: clamp(18px,2vw,32px); }
    .afx-donate { font-family: var(--font-display); font-size: clamp(14px,1.4vw,24px); letter-spacing: -0.01em; text-transform: uppercase; color: #fff; }
    .afx-right .pill { font-size: clamp(12px,1.2vw,16px); }

    @media (max-width: 900px) {
      /* MVW: no pinned/sliding behavior on mobile — stack statically */
      .mvw { height: auto !important; }
      .mvw-sticky { display: none; }
      .mvw-stack { display: flex; flex-direction: column; gap: clamp(36px,9vw,52px); padding: clamp(48px,10vw,64px) 24px; }

      .abox { grid-template-columns: 1fr; gap: 36px; }
      .abox-mark { align-items: center; text-align: center; }
      .abox-grid { order: -1; }

      .team-sec { grid-template-columns: 1fr; gap: 48px; }
      .team-row { grid-template-columns: 1fr 1fr; gap: 18px; }

      .involved { flex-direction: column; align-items: flex-start; gap: 22px; }
      .inv-form { width: 100%; }
      .inv-input { flex: 1; min-width: 0; }

      .afx-footrow { flex-direction: column; align-items: flex-start; gap: 24px; }
      .afx-right { flex-wrap: wrap; }
      .afx-socials { gap: 16px 22px; }
    }
    @media (max-width: 520px) {
      .team-row { grid-template-columns: 1fr; max-width: 320px; }
      .hero-mission { font-size: 13px; }
      .afx-right { width: 100%; justify-content: space-between; }
      .afx-right .pill { flex: 1; }
    }
  </style>

  <script>
    const sec = document.getElementById("mvw");
    const tabs = Array.from(document.querySelectorAll<HTMLElement>(".mvw-tab"));
    const bodies = Array.from(document.querySelectorAll<HTMLElement>(".mvw-text"));
    const N = tabs.length;
    let cur = -1, ticking = false;
    function setActive(i: number) {
      if (i === cur) return;
      cur = i;
      tabs.forEach((t) => t.classList.toggle("on", +(t.dataset.i || 0) === i));
      bodies.forEach((b) => b.classList.toggle("on", +(b.dataset.i || 0) === i));
    }
    function update() {
      ticking = false;
      if (!sec) return;
      const r = sec.getBoundingClientRect();
      const scrollable = sec.offsetHeight - window.innerHeight;
      const p = Math.max(0, Math.min(0.999, -r.top / scrollable));
      setActive(Math.min(N - 1, Math.floor(p * N)));
    }
    function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(update); } }
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();
  </script>
</Base>
